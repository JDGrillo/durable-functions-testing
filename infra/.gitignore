# .gitignore for Terraform

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which may contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock file (optional - some teams commit this)
# .terraform.lock.hcl

# Ignore plan output files
*.tfplan
tfplan

# Ignore local environment files
.env
.env.local

# Ignore backup files
*.backup
*.bak

# Ignore Mac files
.DS_Store

# Ignore editor files
.vscode/
.idea/
*.swp
*.swo
*~
